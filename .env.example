# Reddit API credentials (free at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=POP!ularReviews/1.0 by YourUsername

# Optional: SerpAPI key for broader Google review coverage
# Free tier at https://serpapi.com (100 searches/month)
SERPAPI_KEY=your_serpapi_key_here

# App config
PORT=8000
